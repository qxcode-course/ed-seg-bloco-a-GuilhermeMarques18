            "content": "package main\n\nimport (\n\t\"fmt\"\n)\n\nfunc balanceada(key string) bool {\n\tvar load []rune\n\n\tchaveamento := map[rune]rune{\n\t\t')': '(',\n\t\t'}': '{',\n\t\t']': '[',\n\t}\n\n\tfor _, v := range key {\n\t\tif v == '(' || v == '{' || v == '[' {\n\t\t\tload = append(load, v)\n\t\t\tcontinue\n\t\t}\n\t\tif len(load) == 0 {\n\t\t\treturn false\n\t\t}\n\n\t\tif open, i := chaveamento[v]; i {\n\n\t\t\tif len(chaveamento) == 0 {\n\t\t\t\treturn false\n\t\t\t}\n\n\t\t\ttop := load[len(load)-1]\n\t\t\tload = load[:len(load)-1]\n\n\t\t\tif top != open {\n\t\t\t\treturn false\n\t\t\t}\n\n\t\t}\n\t}\n\treturn len(load) == 0\n}\nfunc main() {\n\tvar n string\n\tfmt.Scan(&n)\n\n\tif balanceada(n) {\n\t\tfmt.Println(\"balanceado\")\n\t} else {\n\t\tfmt.Println(\"nao balanceado\")\n\t}\n\n}\n",
